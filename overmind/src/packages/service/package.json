{
  "name": "overmind-service",
  "version": "0.1.0",
  "description": "Overmind scaffold service implementation over IPC.",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "overmind-service": "dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts src/bin.ts --dts --format cjs --clean",
    "dev": "tsup src/index.ts src/bin.ts --dts --format cjs --watch"
  },
  "dependencies": {
    "overmind-api": "0.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.3"
  }
}