{
  "name": "overmind-core",
  "version": "0.1.0",
  "description": "Shared Overmind core types and contracts for services and clients.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  }
}
