{
  "name": "overmind-workspace",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w packages/overmind-sdk && npm run build -w packages/overmind-cli && npm run build -w packages/overmind",
    "test": "npm run test:unit",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:unit:coverage": "vitest run --config vitest.unit.config.ts --coverage",
    "test:coverage": "npm run test:unit:coverage",
    "lint": "eslint packages/",
    "lint:fix": "eslint packages/ --fix",
    "clean": "rimraf packages/*/dist"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.3.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "globals": "^17.6.0",
    "rimraf": "^6.1.3",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.1.5"
  }
}
