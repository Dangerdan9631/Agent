{
  "all": true,
  "check-coverage": true,
  "functions": 100,
  "branches": 100,
  "lines": 0,
  "statements": 0,
  "include": [
    "packages/cli/src/**/*.ts"
  ],
  "exclude": [
    "packages/**/dist/**",
    "packages/core/test/**",
    "**/*.test.ts",
    "**/tsup.config.ts"
  ],
  "reporter": [
    "text",
    "html"
  ],
  "report-dir": "coverage/functional"
}