{
  "name": "agentconfig",
  "version": "0.1.0",
  "description": "Write AI agent instructions once. Generate native directive files for every agent.",
  "keywords": ["ai", "agents", "copilot", "cursor", "claude", "codex", "gemini", "windsurf", "cline"],
  "license": "MIT",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.0",
    "zod": "^3.22.4",
    "diff": "^5.2.0",
    "chokidar": "^3.5.3",
    "fast-glob": "^3.3.2",
    "@iarna/toml": "^2.2.5"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.3.3",
    "@types/node": "^20.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/diff": "^5.2.1",
    "@types/iarna__toml": "^2.0.5"
  }
}
