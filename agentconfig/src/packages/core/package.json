{
  "name": "agentconfig",
  "version": "0.1.0",
  "description": "Write AI agent instructions once. Generate native directive files for every agent.",
  "license": "MIT",
  "engines": {
    "node": ">=24"
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.1",
    "zod": "^4.4.3",
    "diff": "^9.0.0",
    "chokidar": "^5.0.0",
    "fast-glob": "^3.3.3",
    "@iarna/toml": "^2.2.5"
  },
  "devDependencies": {
    "@types/iarna__toml": "^2.0.5",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.6.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  }
}
