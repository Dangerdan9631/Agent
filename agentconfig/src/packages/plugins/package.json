  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "agentconfig-api": "0.1.0",
    "fast-glob": "^3.3.3",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/iarna__toml": "^2.0.5",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.6.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  }
}