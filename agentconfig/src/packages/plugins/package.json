{
  "name": "agentconfig-plugins",
  "version": "0.1.0",
  "description": "Built-in directive types and agent plugins for agentconfig.",
  "license": "MIT",
  "engines": {
    "node": ">=24"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
