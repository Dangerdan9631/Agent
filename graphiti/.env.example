# Set this to the private LAN IP or interface bind you want to expose.
# 0.0.0.0 publishes on all local interfaces; keep your firewall on private/LAN only.
LAN_BIND_IP=0.0.0.0
AGENT_DOCKER_NETWORK=agent-services

# Host-local defaults used by the smoke test.
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_API_KEY=ollama
OLLAMA_CHAT_MODEL=qwen3:4b
OLLAMA_SMALL_MODEL=qwen3:4b
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_EMBEDDING_DIM=768

# Container-to-container URL used by the REST, MCP, and wrapper services.
OLLAMA_OPENAI_BASE_URL=http://ollama:11434/v1

NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=graphiti-password
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687

GRAPHITI_REST_PORT=8000
GRAPHITI_MCP_PORT=8001
GRAPHITI_WRAPPER_PORT=8002
GRAPHITI_MCP_GROUP_ID=main

GRAPHITI_ENABLE_RERANKER=false
GRAPHITI_TELEMETRY_ENABLED=false
SEMAPHORE_LIMIT=3
