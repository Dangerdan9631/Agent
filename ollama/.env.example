LAN_BIND_IP=0.0.0.0
AGENT_DOCKER_NETWORK=agent-services
OLLAMA_PORT=11434
OLLAMA_KEEP_ALIVE=24h
OLLAMA_CONTEXT_LENGTH=1024
# Set to true to run Ollama natively on the host (uses macOS Metal GPU via Homebrew)
# instead of in Docker. When true the Docker ollama service is skipped entirely.
OLLAMA_NATIVE=true
OLLAMA_CHAT_MODEL=qwen3.5:4b
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_BASE_URL=http://127.0.0.1:11434